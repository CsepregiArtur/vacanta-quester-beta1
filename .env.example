# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ═══ AI Provider (Pasul 15-16) ═══
# AI_PROVIDER: gemini | openai | local
AI_PROVIDER=gemini
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENAI_API_KEY="sk-your-key"

# ═══ Redis / BullMQ (Pasul 16) ═══
REDIS_HOST=localhost
REDIS_PORT=6379

# ═══ GitHub Issues — raportare automată erori ═══
# GITHUB_TOKEN: Personal Access Token (classic) cu drepturi "issues: write"
#   1. Mergi la https://github.com/settings/tokens
#   2. Creează un token clasic cu scopul "public_repo" sau "repo" (privat)
#   3. Copiază token-ul aici
GITHUB_TOKEN="ghp_your_github_token_here"

# GITHUB_REPO: Repo-ul unde se crează issues (format: "utilizator/repo")
#   Exemplu: "csepregi/vacanta-quester"
GITHUB_REPO="csepregi/vacanta-quester"
